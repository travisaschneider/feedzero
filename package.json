    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.1.42",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^3.0.0",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.8.4",
