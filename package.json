{
  "name": "feedzero",
  "version": "0.1.0",
  "description": "Privacy-first RSS reader",
  "type": "module",
  "scripts": {
    "dev": "vite --port 3000",
    "build": "vite build",
    "build:api": "node scripts/build-api.js",
    "build:all": "vite build && node scripts/build-api.js",
    "test": "vitest run",
